{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 ~/.claude/hooks/session_start_context.py"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ~/.claude/hooks/pre_tool_risk_guard.py",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ~/.claude/hooks/pre_tool_risk_guard.py",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/skills/continuous-learning-v2/hooks/observe.sh pre",
          "timeout": 10
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ~/.claude/hooks/post_tool_commit_ready_hint.py",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "python3 ~/.claude/hooks/post_tool_git_push_hint.py",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/skills/continuous-learning-v2/hooks/observe.sh post",
          "timeout": 10
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 ~/.claude/hooks/stop_self_check.py",
          "timeout": 5
        }
      ]
    }
  ]
}
